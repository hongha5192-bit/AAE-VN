{"name": "DecayFlowStdMom_Z", "expr": "ZSCORE(TS_RANK(TS_PCTCHANGE($close, 5), 5) * (DECAYLINEAR($net_foreign_val - DELAY($net_foreign_val, 1), 10) / (TS_STD($return, 14) + 1e-8)))", "Information_Ratio_with_cost": 0.9282}
