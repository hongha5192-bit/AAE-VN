{"name": "NormPriceDevWeightedMom7D", "expr": "ZSCORE( MAX( MIN( (-TS_SUM($return,4)/MAX(TS_STD($return,4),1e-8)) * ( TS_ZSCORE(($net_foreign_val-TS_MEDIAN($net_foreign_val,20))/(EMA($volume,20)+1e-8),20) + TS_ZSCORE(($net_foreign_vol-TS_MEDIAN($net_foreign_vol,20))/(EMA(ABS($return),20)+1e-8),20) ), 3), -3) )", "Information_Ratio_with_cost": 0.183623}
{"name": "PriceSlope_VolRatio_Rank_5D", "expr": "(REGBETA($return, SEQUENCE(5),5)/(TS_STD($return,5)+1e-8)) * ((2/(1 + EXP(-5*((EMA($net_foreign_val,20)/(EMA($net_foreign_vol,20)+1e-8)) - MEAN(EMA($net_foreign_val,20)/(EMA($net_foreign_vol,20)+1e-8)))))) - 1) * RANK($net_foreign_vol)", "Information_Ratio_with_cost": 0.183592}
