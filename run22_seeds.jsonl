{"name": "EWMA_Cross_Vol_LogMomentum_5D", "expr": "($close > TS_MAX($high, 15) && TS_RANK($volume, 20) > 0.75) ? (( $close - TS_MAX($high, 15) ) / ( TS_MEAN(MAX($high - $low, ABS($high - DELAY($close, 1)), ABS($low - DELAY($close, 1))), 10) + 1e-8 ) * TS_RANK($volume, 20)) : 0", "Information_Ratio_with_cost": 0.928154}
